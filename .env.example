# Public app URL, used for share links and Stripe redirects
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Anthropic API key, powers the verdict engine
ANTHROPIC_API_KEY=

# Supabase project URL and anon key, client-side access
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key, server-only, bypasses RLS for crons and webhooks
SUPABASE_SERVICE_ROLE_KEY=

# Stripe secret key, server-only, used for Checkout and Portal
STRIPE_SECRET_KEY=

# Stripe webhook signing secret, verifies webhook payloads
STRIPE_WEBHOOK_SECRET=

# Stripe publishable key, client-side
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe recurring price id for the $4.99 weekly plan
STRIPE_PRICE_ID=

# Resend API key, sends locker drop alerts and detention prompts
RESEND_API_KEY=

# From address used on transactional emails
EMAIL_FROM=

# Shared secret required by cron routes
CRON_SECRET=

# Amazon Associates tag, appended to swap search links when present
AMAZON_AFFILIATE_TAG=
